[rpmfusion-free-rawhide]
name=RPMFus - Rawhide - Free
metalink=https://mirrors.rpmfusion.org/metalink?repo=free-fedora-rawhide&arch=$basearch
enabled=1
enabled_metadata=1
type=rpm-md
gpgcheck=0
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora-rawhide file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora-latest

[rpmfusion-free-rawhide-debuginfo]
name=RPMFus - Rawhide - Free - Dbg
metalink=https://mirrors.rpmfusion.org/metalink?repo=free-fedora-rawhide-debug&arch=$basearch
enabled=1
type=rpm-md
gpgcheck=1
repo_gpgcheck=0
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora-rawhide file:///etc/pki/rpm-gpg/RPM-GPG-KEY-rpmfusion-free-fedora-latest
