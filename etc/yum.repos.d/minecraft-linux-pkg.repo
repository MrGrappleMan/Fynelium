[minecraft-linux-pkg]
name=minecraft-linux-pkg
baseurl=https://minecraft-linux.github.io/pkg/fedora-41
enabled=1
repo_gpgcheck=0
type=rpm
gpgcheck=1
gpgkey=https://minecraft-linux.github.io/pkg/deb/pubkey.gpg
metadata_expire=1h
skip_if_unavailable=True
deltarpm=True
fastestmirror=True
max_parallel_downloads=20
retries=0
countme=1