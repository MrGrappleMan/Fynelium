[boinc-nightly]
name = BOINC nightly repo
baseurl = https://boinc.berkeley.edu/dl/linux/nightly/fc40
enabled = 1
gpgcheck = 1
gpgkey = https://boinc.berkeley.edu/dl/linux/nightly/fc40/boinc.gpg
metadata_expire=1h
skip_if_unavailable=True
deltarpm=True
fastestmirror=True
max_parallel_downloads=20
retries=0